# Assignment 8 - E-Commerce Order Analytics System

import pandas as pd

# Step 1: Sample dataset with inconsistencies
data = {
    "OrderID": ["O1","O2","O3","O4","O5"],
    "Customer": ["A","B","C","D","E"],
    "Product": ["Laptop","Phone","Shoes","Table","Book"],
    "Quantity": [1,2,None,3,1],
    "Price": [50000,20000,3000,7000,None]
}
df = pd.DataFrame(data)

# Step 2: Data Cleaning
df = df.fillna(0)              # handle missing values
df = df.drop_duplicates()      # remove duplicates
df["TotalAmount"] = df["Quantity"] * df["Price"]

# Step 3: Save cleaned dataset
df.to_csv("ECommerce_Cleaned.csv", index=False)

# Step 4: Exploration
print(df.head())
print(df.describe())
