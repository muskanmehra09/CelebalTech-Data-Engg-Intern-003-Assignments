# Week 7 Assignment - Data Cleaning with Pandas

import pandas as pd

# Step 1: Load CSV
df = pd.read_csv("Superstore.csv")

# Step 2: Explore Data
print(df.head())
print(df.tail())
print(df.shape)
print(df.columns)
print(df.dtypes)

# Step 3: Handle Missing Values
df = df.fillna(0)   # simple fill with 0

# Step 4: Basic Operations
filtered = df[df['Category'] == 'Furniture']
selected = df[['Order ID','Product Name','Sales','Quantity','Discount','Profit']]

# Step 5: Remove Duplicates
df = df.drop_duplicates()

# Step 6: Derived Column
df['total_amount'] = df['Sales'] * df['Quantity']

# Step 7: Save Cleaned Dataset
df.to_csv("Superstore_Cleaned.csv", index=False)
